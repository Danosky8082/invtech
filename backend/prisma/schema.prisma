generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int     @id @default(autoincrement())
  username       String  @unique
  email          String  @unique
  passwordHash   String  @map("password_hash")
  virtualBalance Float   @default(10000) @map("virtual_balance")
  createdAt      DateTime @default(now()) @map("created_at")

  simulations    UserSimulation[]
  watchlists     Watchlist[]
  backtests      Backtest[]

  @@map("users")
}

model Asset {
  id             Int     @id @default(autoincrement())
  name           String
  type           String   // "stock", "bond", "etf", "crypto"
  ticker         String? @unique
  expectedReturn Float   @map("expected_return")
  riskLevel      String  @map("risk_level") // "low", "medium", "high"

  simulations    UserSimulation[]
  watchlists     Watchlist[]
  backtests      Backtest[]

  @@map("assets")
}

model UserSimulation {
  id              Int      @id @default(autoincrement())
  userId          Int      @map("user_id")
  assetId         Int      @map("asset_id")
  amountInvested  Float    @map("amount_invested")
  expectedProfit  Float    @map("expected_profit")
  simulatedAt     DateTime @default(now()) @map("simulated_at")

  originalAmount   Float?  @map("original_amount")
  originalCurrency String? @map("original_currency")
  priceAtSimulation Float? @map("price_at_simulation")
  tickerAtSimulation String? @map("ticker_at_simulation")

  user   User   @relation(fields: [userId], references: [id])
  asset  Asset  @relation(fields: [assetId], references: [id])

  @@map("user_simulations")
}

model Watchlist {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  assetId   Int      @map("asset_id")
  addedAt   DateTime @default(now()) @map("added_at")

  user   User   @relation(fields: [userId], references: [id])
  asset  Asset  @relation(fields: [assetId], references: [id])

  @@unique([userId, assetId])
  @@map("watchlists")
}

model Backtest {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  assetId     Int      @map("asset_id")
  ticker      String   @map("ticker")
  strategy    String   // "buy_and_hold", "ma_crossover", "rsi", etc.
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  results     Json     @map("results")  // Stores all metrics and trade log
  createdAt   DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id])
  asset  Asset  @relation(fields: [assetId], references: [id])

  @@map("backtests")
}