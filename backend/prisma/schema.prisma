generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int     @id @default(autoincrement())
  username       String  @unique
  email          String  @unique
  passwordHash   String  @map("password_hash")
  virtualBalance Float   @default(10000) @map("virtual_balance")
  createdAt      DateTime @default(now()) @map("created_at")

  simulations    UserSimulation[]

  @@map("users")
}

model Asset {
  id             Int     @id @default(autoincrement())
  name           String
  type           String   // "stock" or "bond"
  ticker         String?  @unique
  expectedReturn Float    @map("expected_return")
  riskLevel      String   @map("risk_level") // "low", "medium", "high"

  simulations    UserSimulation[]

  @@map("assets")
}

model UserSimulation {
  id              Int      @id @default(autoincrement())
  userId          Int      @map("user_id")
  assetId         Int      @map("asset_id")
  amountInvested  Float    @map("amount_invested")
  expectedProfit  Float    @map("expected_profit")
  simulatedAt     DateTime @default(now()) @map("simulated_at")

  // ✅ Original currency fields (store what the user entered)
  originalAmount  Float    @map("original_amount")
  originalCurrency String  @map("original_currency") @default("USD")

  // ✅ NEW: Price at simulation time (for real‑time portfolio tracking)
  priceAtSimulation Float? @map("price_at_simulation")

  // ✅ NEW: Ticker used at simulation (for external assets not in DB)
  tickerAtSimulation String? @map("ticker_at_simulation")

  user   User   @relation(fields: [userId], references: [id])
  asset  Asset  @relation(fields: [assetId], references: [id])

  @@map("user_simulations")
}